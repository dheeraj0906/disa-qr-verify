# ── Backend (copy to backend/.env) ──────────────────────────────────────────

# Supabase PostgreSQL pooler URL
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — set to your Netlify frontend URL in production
FRONTEND_URL=http://localhost:5173

# App config
PORT=4000
MUNICIPALITY_NAME=Khammam
LATE_THRESHOLD_IST=07:00

# ── Frontend (copy to frontend/.env) ─────────────────────────────────────────

VITE_API_URL=http://localhost:4000/api
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=disa_unsigned_preset
