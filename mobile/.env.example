# Backend API (leave empty for production — defaults to Render URL hardcoded in api.ts)
EXPO_PUBLIC_API_URL=

# Cloudinary — unsigned upload for photo storage
# 1. Go to https://cloudinary.com and create a free account
# 2. Copy your Cloud Name from the dashboard
# 3. Settings → Upload → Upload presets → Add unsigned preset, copy its name
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=placeholder
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
