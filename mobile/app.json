{
  "expo": {
    "name": "DISA QR Verify",
    "slug": "disa-qr-verify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "disaqrverify",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.disa.qrverify",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Required for geo-stamping task photos.",
        "NSCameraUsageDescription": "Required for QR scanning and photo capture.",
        "NSFaceIDUsageDescription": "Used for quick biometric login."
      },
      "associatedDomains": ["applinks:disa-qr-verify.netlify.app"]
    },
    "android": {
      "package": "com.disa.qrverify",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "backgroundColor": "#2E7D32"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "disa-qr-verify.netlify.app",
              "pathPrefix": "/scan"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        { "cameraPermission": "Allow DISA to access your camera for QR scanning and photos." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow DISA to access your photos." }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow DISA to use your location to geo-stamp task photos."
        }
      ],
      [
        "expo-notifications",
        { "icon": "./assets/images/icon.png", "color": "#2E7D32" }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2E7D32",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "react-native-maps",
        { "googleMapsApiKey": "" }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "3fe084b7-a66e-4152-8f4a-2e974d54eea2"
      }
    }
  }
}
